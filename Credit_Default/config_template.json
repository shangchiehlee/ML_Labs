{
    "schema_version": "1.0",
    "subscription_id": "<YOUR_SUBSCRIPTION_ID>",
    "resource_group": "<YOUR_RESOURCE_GROUP>",
    "workspace_name": "<YOUR_WORKSPACE_NAME>",
    "compute_name": "<YOUR_COMPUTE_INSTANCE>",
    "job_base_name": "credit_default_train",
    "operational_settings": {
        "training_timeout_seconds": 86400,
        "batch_size": 5000,
        "inference_n_jobs": 2,
        "enable_json_logging": true,
        "dry_run_rows": 1000
    },
    "training_hyperparameters": {
        "test_train_ratio": 0.2,
        "learning_rate": 0.1,
        "max_iter": 100
    },
    "feature_definitions": {
        "categorical": ["SEX", "EDUCATION", "MARRIAGE"],
        "target": "default payment next month"
    },
    "schema_expectations": {
        "required_columns": ["LIMIT_BAL", "SEX", "EDUCATION", "MARRIAGE", "AGE", "PAY_0", "BILL_AMT1", "PAY_AMT1"],
        "dtypes": {
            "LIMIT_BAL": "float64",
            "AGE": "int64",
            "BILL_AMT1": "float64"
        }
    },
    "output_schema_expectations": {
        "required_columns": ["LIMIT_BAL", "Probability of Default"],
        "dtypes": {
            "Probability of Default": "float64"
        }
    }
}